{
  "schema_version": "1.0",
  "language": "ru-RU",
  "domain": "light",
  "defaults": {
    "brightness_delta_pct": 20,
    "color_temp_delta_k": 800,
    "transition_s": 0.8
  },
  "intensity_scalars": {
    "small": 0.5,
    "medium": 1.0,
    "strong": 1.75,
    "max": 5.0
  },
  "intensifiers": [
    {
      "id": "INT_SMALL",
      "type": "scalar",
      "value": "small",
      "patterns": [
        "чуть",
        "чуть-чуть",
        "немного",
        "слегка",
        "капельку",
        "малость"
      ]
    },
    {
      "id": "INT_STRONG",
      "type": "scalar",
      "value": "strong",
      "patterns": [
        "сильно",
        "значительно",
        "намного",
        "гораздо",
        "прям",
        "прямо",
        "резко"
      ]
    },
    {
      "id": "INT_MAX",
      "type": "scalar",
      "value": "max",
      "patterns": [
        "максимально",
        "на максимум",
        "до максимума",
        "по максимуму",
        "на полную",
        "на полную мощность"
      ]
    }
  ],
  "politeness_and_fillers": [
    {
      "id": "FILLER",
      "type": "ignore",
      "patterns": [
        "пожалуйста",
        "плиз",
        "будь добр",
        "будь добра",
        "давай",
        "ну",
        "эй",
        "слушай",
        "окей",
        "ладно"
      ]
    }
  ],
  "negations": [
    {
      "id": "NEG_NOT_OFF",
      "type": "constraint",
      "value": "avoid_turn_off",
      "patterns": [
        "не выключай",
        "не вырубай",
        "не гаси",
        "не надо выключать",
        "не надо вырубать",
        "не отключай"
